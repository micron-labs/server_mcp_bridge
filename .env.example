# ===========================================
# Server MCP Bridge Configuration
# ===========================================
# Copy to .env and edit values

# Authentication
# Generate with: openssl rand -hex 32
API_KEY=your_secure_random_token

# Server
HOST=0.0.0.0
PORT=8080
ENABLE_SSL=false
SSL_CERT=
SSL_KEY=

# Security
ALLOWED_IPS=
RATE_LIMIT=60
ALLOWED_ROOT=/
DANGEROUS_TOOLS_ENABLED=true
ENABLE_RAW_QUERIES=false

# MySQL / MariaDB
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=

# Web Server
NGINX_CONFIG_DIR=/etc/nginx
APACHE_CONFIG_DIR=/etc/apache2
CERTBOT_PATH=/usr/bin/certbot

# Sandbox
SANDBOX_TEMP_DIR=/tmp/mcp_sandbox
SANDBOX_DEFAULT_TIMEOUT=30
SANDBOX_DEFAULT_MEMORY_MB=256
SANDBOX_ENABLE_NETWORK=false

# Logging
LOG_FILE=logs/server.log
LOG_LEVEL=info
